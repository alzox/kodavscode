{
  "name": "koda-theme",
  "displayName": "Koda Theme",
  "description": "A minimalist VS Code theme ported from koda.nvim.",
  "version": "0.0.1",
  "publisher": "you-gao",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "dark",
    "light",
    "minimal",
    "koda"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Koda Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/koda-dark-color-theme.json"
      },
      {
        "label": "Koda Light",
        "uiTheme": "vs",
        "path": "./themes/koda-light-color-theme.json"
      },
      {
        "label": "Koda Moss",
        "uiTheme": "vs-dark",
        "path": "./themes/koda-moss-color-theme.json"
      },
      {
        "label": "Koda Glade",
        "uiTheme": "vs",
        "path": "./themes/koda-glade-color-theme.json"
      }
    ]
  }
}
